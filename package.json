{
  "name": "reuse-hub",
  "version": "1.0.0",
  "description": "A hub for launching apps, games, and websites",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "backend": "python backend/server.py"
  },
  "build": {
    "appId": "com.reuse-hub.app",
    "productName": "Reuse Hub",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Reuse Hub.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
